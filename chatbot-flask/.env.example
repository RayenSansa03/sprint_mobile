# ============================================================
# .env.example — Variables d'environnement pour chatbot-flask
# Copiez ce fichier en .env et remplissez les valeurs réelles.
# NE JAMAIS committer le fichier .env dans le dépôt.
# ============================================================

# ── Groq LLM ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-70b-8192

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agrismart

# ── MCP Server (exécution des requêtes MongoDB) ─────────────────────
# URL de l'endpoint d'exécution du MCP server (mcp_server/app.py)
MCP_SERVER_URL=http://localhost:5001/execute
MCP_SERVER_PORT=5001
MCP_TIMEOUT=10

# ── Serveur Flask (agents LangGraph) ──────────────────────
FLASK_PORT=5002
ANGULAR_URL=http://localhost:4200

# ── Sécurité endpoint /ingest ────────────────────────────────
INGEST_API_KEY=change_me_secret_ingest_key_min32chars

# ── Base vectorielle Chroma ──────────────────────────────────
VECTORSTORE_PATH=agrismart_agents/knowledge/vectorstore
CATALOG_PATH=agrismart_agents/knowledge/providers_catalog.json

# ── OpenAI (embeddings Chroma uniquement, optionnel) ─────────
# Utilisé seulement si l'endpoint /ingest est appelé.
# Remplacer par HuggingFace pour éviter les coûts OpenAI.
OPENAI_API_KEY=
CHATBOT_RERANK_CROSS_ABS_MIN_SCORE=0.35
CHATBOT_MAX_RULES_CONFIDENCE=0.68
CHATBOT_INTENT_SEMANTIC_THRESHOLD=0.55
CHATBOT_MAX_MESSAGE_CHARS=1200
CHATBOT_RATE_LIMIT_PER_MIN=45

# Usage analytics agent
CHATBOT_ANALYTICS_EVENTS_PATH=./artifacts/analytics_events.jsonl
CHATBOT_ANALYTICS_REPORT_PATH=./artifacts/rapport.json
CHATBOT_ANALYTICS_AUTO_ANALYZE=true
CHATBOT_ANALYTICS_MAX_EVENTS=5000
CHATBOT_APP_LOG_PATH=
